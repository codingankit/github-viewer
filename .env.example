# GitHub personal access token (public read-only is enough)
# Used server-side to call the GitHub API
GITHUB_API_TOKEN=""

# Port the Express server runs on (default: 3000). Always serves the API, and also
# serves the built frontend when using the "npm run build" + "npm start" flow
PORT=3000

# Port the app opens on when using "npm run dev" (default: 8080).
# The API still runs on PORT above — requests to /api/* are proxied
# from this port to PORT automatically
DEV_PORT=8080

# Set automatically to "production" by "npm run build" — no need to touch it.
# Default is "development" — keep it as-is for "npm run dev"
NODE_ENV="development"